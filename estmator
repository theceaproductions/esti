    show_company_name BOOLEAN NOT NULL DEFAULT TRUE,

    -- Advanced
    custom_css TEXT,
    welcome_message TEXT,

    -- Timestamps
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

